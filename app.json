{
  "expo": {
    "name": "Rewind",
    "slug": "Rewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rewind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "bstudenc",
    "extra": {
      "eas": {
        "projectId": "7aac9bca-c4dd-4f6e-b830-1d72d34f11f9"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rewind.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSCameraUsageDescription": "Rewind needs access to your camera to capture your daily moments.",
        "NSPhotoLibraryUsageDescription": "Rewind needs access to your photo library to save your Rewinds."
      },
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.rewind.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5757",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF5757",
          "dark": {
            "backgroundColor": "#FF5757"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
